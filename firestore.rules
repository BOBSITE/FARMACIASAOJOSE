rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId} (matches auth.uid)
    // Fields:
    //   - uid: string (required)
    //   - email: string (required, email format)
    //   - displayName: string (required)
    //   - cpf: string (optional, 11 digits)
    //   - role: string (required, enum: CLIENT, ADMIN, FARMACEUTICO, ATENDENTE)
    //   - loyaltyPoints: number (required, >= 0)
    //   - createdAt: timestamp (required)
    //
    // Collection: products
    // Document ID: {productId}
    // Fields:
    //   - name: string (required)
    //   - price: number (required, > 0)
    //   - stock: number (required, >= 0)
    //   - category: string (required)
    //   ...
    //
    // Collection: orders
    // Document ID: {orderId}
    // Fields:
    //   - userId: string (required)
    //   - status: string (required, enum)
    //   - total: number (required, > 0)
    //   ...
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == 'betvdoc@gmail.com' ||
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'ADMIN'));
    }
    
    function isStaff() {
      return isAuthenticated() && 
        (isAdmin() || 
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['FARMACEUTICO', 'ATENDENTE']));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'loyaltyPoints', 'displayName', 'createdAt']) &&
             data.uid is string &&
             data.email is string &&
             data.displayName is string &&
             data.role in ['CLIENT', 'ADMIN', 'FARMACEUTICO', 'ATENDENTE'] &&
             data.loyaltyPoints is number && data.loyaltyPoints >= 0 &&
             data.createdAt is string &&
             (!('cpf' in data) || (data.cpf is string && (data.cpf.size() == 11 || data.cpf.size() == 0)));
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'price', 'stock', 'category']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.price is number && data.price > 0 &&
             data.stock is number && data.stock >= 0;
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['userId', 'status', 'total', 'items']) &&
             data.userId is string &&
             data.status in ['PENDING', 'APPROVED', 'SHIPPED', 'DELIVERED', 'CANCELLED'] &&
             data.total is number && data.total >= 0;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && 
                      (isOwner(userId) && request.resource.data.role == 'CLIENT' || isAdmin());
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && 
                      (isOwner(userId) && request.resource.data.role == resource.data.role || isAdmin());
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /orders/{orderId} {
      allow read: if isAuthenticated() && (isOwner(resource.data.userId) || isStaff());
      allow create: if isAuthenticated() && isValidOrder(request.resource.data) && 
                      (isOwner(request.resource.data.userId) || isStaff());
      allow update: if isStaff();
    }

    match /{path=**} {
      allow read, write: if false;
    }
  }
}
